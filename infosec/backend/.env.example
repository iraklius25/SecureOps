# InfoSec Platform — Backend Environment
# Copy to .env and fill in your values

NODE_ENV=production
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://infosec_user:CHANGE_ME_STRONG_PASSWORD@localhost:5432/infosec_db

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS

# Frontend URL (for CORS) — use your server IP/domain, no port (Nginx handles port 80)
FRONTEND_URL=http://YOUR_SERVER_IP

# Log level: error | warn | info | debug
LOG_LEVEL=info

# TLS verification for outbound API calls (Shodan, NVD, AbuseIPDB).
# Set to false (default) if the server is behind a corporate SSL-inspection
# proxy that replaces external certificates — you will see the error
# "self-signed certificate in certificate chain" if this is needed.
# Set to true only when the server has direct internet access with no proxy.
HTTPS_REJECT_UNAUTHORIZED=false
